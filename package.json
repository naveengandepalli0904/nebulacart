{
  "name": "nebulacart",
  "version": "1.0.0",
  "description": "NebulaCart - Full Stack E-Commerce Platform",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "concurrently \"nodemon backend/server.js\" \"cd frontend && npm start\"",
    "install-all": "npm install && cd frontend && npm install",
    "build": "cd frontend && npm run build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "concurrently": "^8.2.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.3.0",
    "mongoose": "^8.0.1",
    "multer": "^1.4.5-lts.1",
    "nodemon": "^3.0.2",
    "stripe": "^14.4.0"
  }
}
